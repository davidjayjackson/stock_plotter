{
  "expo": {
    "name": "stock_plotter",
    "slug": "stock_plotter",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.davidjayjackson.stockplotter"
    },
    "android": {
      "package": "com.davidjayjackson.stockplotter",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/52059a7b-6696-4491-8dd2-203d3500cd2d"
    },
    "extra": {
      "eas": {
        "projectId": "52059a7b-6696-4491-8dd2-203d3500cd2d"
      }
    }
  }
}
